# ─────────────────────────────────────────────────────────────────────────────
# TIPSON — variables d'environnement (copier en .env.local, et configurer Vercel)
# Toutes les clés Stripe DOIVENT provenir du même compte Stripe.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.tipson.online   # URL publique (sert au logo email, liens onboarding)

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...      # clé anon/publishable
SUPABASE_SERVICE_ROLE_KEY=eyJ...                 # SECRÈTE (service role, bypass RLS)

# ── Stripe (paiements + Connect) ──────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...   # publique (pk_test_ = test, pk_live_ = prod)
STRIPE_SECRET_KEY=sk_test_...                    # SECRÈTE (même compte/mode que la publique)
STRIPE_WEBHOOK_SECRET=whsec_...                  # signing secret de l'endpoint /api/stripe/webhook
PLATFORM_FEE_PERCENT=10                          # commission par défaut (override en base, admin)

# ── Modération des messages ───────────────────────────────────────────────────
OPENAI_API_KEY=                                  # OpenAI Moderation (principal). Vide = dictionnaire seul
PERSPECTIVE_API_KEY=                             # Google Perspective (dernier repli, optionnel)

# ── Emailing (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=                                  # récap de soirée au DJ. Vide = pas d'email
EMAIL_FROM=TIPSON <noreply@tipson.online>        # expéditeur (domaine à vérifier dans Resend)

# ── Liens musicaux (Odesli / song.link) ──────────────────────────────────────
ODESLI_API_KEY=                                  # lève la limite de débit (sinon repli api.song.link)
SONGLINK_API_KEY=                                # alias historique d'ODESLI_API_KEY (optionnel)

# ── Mode Jukebox (Apple Music via MusicKit JS) ───────────────────────────────
NEXT_PUBLIC_APPLE_MUSIC_TOKEN=                   # developer token MusicKit (compte Apple Developer)

# ── Recherche Spotify (optionnel — iTunes par défaut) ─────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── TIPSON Studio (téléchargement desktop, réservé aux comptes DJ) ────────────
STUDIO_DL_MAC=                                   # URL du .dmg (R2/S3/GitHub Releases). Vide = "bientôt"
STUDIO_DL_WIN=                                   # URL du .exe (installeur Windows)
STUDIO_DL_LINUX=                                 # URL de l'AppImage (optionnel)

# ── Réglages divers ───────────────────────────────────────────────────────────
MAX_REQUESTS_PER_USER=2                          # défaut (override en base, admin)
NEXT_PUBLIC_APPLE_AUTH_ENABLED=false             # bouton "Continuer avec Apple" (provider Supabase requis)
