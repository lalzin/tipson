# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJ...        # clé publishable (anon)
SUPABASE_SERVICE_ROLE_KEY=eyJ...                   # clé service role (SECRÈTE)

# ── Stripe ────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...      # clé publique
STRIPE_SECRET_KEY=sk_test_...                       # SECRET (sk_test_ = test, sk_live_ = production)
PLATFORM_FEE_PERCENT=10                             # commission plateforme sur chaque pourboire (Connect)
STRIPE_WEBHOOK_SECRET=whsec_...                     # secret de signature webhook (démo Connect V2)

# ── Spotify (optionnel — recherche via iTunes par défaut) ─────
SPOTIFY_CLIENT_ID=...
SPOTIFY_CLIENT_SECRET=...

# ── Liens musicaux (Odesli / song.link) ──────────────────────
# Optionnel : clé API Odesli pour lever la limite de 10 req/min (demandée à l'équipe).
# Sans clé, les liens s'affichent quand même mais sont masqués en cas de rate-limit.
SONGLINK_API_KEY=

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://votre-site.netlify.app

# ── Options ───────────────────────────────────────────────────
# Affiche le bouton "Continuer avec Apple" (nécessite un compte Apple Developer
# à 99€/an + provider Apple configuré dans Supabase). Laisser vide pour masquer.
NEXT_PUBLIC_APPLE_AUTH_ENABLED=false
